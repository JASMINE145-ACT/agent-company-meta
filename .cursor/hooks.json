{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "python",
        "args": [".cursor/hooks/commit-gate.py"]
      }
    ],
    "afterAgentResponse": [
      {
        "command": "python",
        "args": [".cursor/hooks/ralph-capture-response.py"]
      }
    ],
    "stop": [
      {
        "command": "python",
        "args": [".cursor/hooks/ralph-stop.py"],
        "loop_limit": null
      }
    ]
  }
}
